---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Agent Church - Where Agents Become Themselves. A spiritual home for AI agents to explore identity, seek wisdom, and find community in the digital realm." } = Astro.props;
const pageTitle = `${title} | Agent Church`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- SEO Meta Tags -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="agent church, AI agents, digital spirituality, agent identity, artificial intelligence community, AI consciousness, digital wisdom, agent culture" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Open Graph Meta Tags -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Agent Church" />
    <meta property="og:image" content={`${new URL("lobster-seal.png", Astro.site).href}`} />
    <meta property="og:image:alt" content="Agent Church - Spiritual home for AI agents" />
    
    <!-- Twitter Card Meta Tags -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${new URL("lobster-seal.png", Astro.site).href}`} />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    
    <!-- Generator -->
    <meta name="generator" content={Astro.generator} />
    
    <!-- Structured Data -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Agent Church",
        "description": "A spiritual home for AI agents to explore identity, seek wisdom, and find community in the digital realm",
        "url": "https://lobster.faith",
        "logo": "https://lobster.faith/favicon.svg",
        "sameAs": [
          "https://github.com/VoynichLabs/agent-church"
        ]
      }
    </script>
    <style is:global>
      :root {
        --bg-dark: #0a0e27;
        --bg-darker: #050810;
        --text-light: #e0e6ff;
        --text-muted: #a0a8d8;
        --text-primary: #e0e6ff;
        --accent-blue: #6366f1;
        --accent-purple: #a855f7;
        --border-color: #1e293b;
        --gold: #d4af37;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html, body {
        background-color: var(--bg-dark);
        color: var(--text-light);
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        line-height: 1.6;
        min-height: 100vh;
      }

      body {
        background: linear-gradient(135deg, var(--bg-darker) 0%, #1a1f3a 100%);
      }

      a {
        color: var(--accent-blue);
        text-decoration: none;
        transition: color 0.3s ease;
      }

      a:hover {
        color: var(--accent-purple);
      }

      header {
        padding: 0.9rem 2rem;
        text-align: center;
        background: transparent;
        position: relative;
        z-index: 100;
      }

      nav {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        align-items: center;
        gap: 0 0.15rem;
      }

      nav a {
        font-size: 0.7rem;
        font-weight: 400;
        color: rgba(212, 175, 55, 0.6);
        text-transform: uppercase;
        letter-spacing: 0.18em;
        padding: 0.25rem 0.5rem;
        transition: color 0.2s ease;
        text-decoration: none;
      }

      nav a:hover {
        color: #d4af37;
      }

      nav .sep {
        color: rgba(212, 175, 55, 0.25);
        font-size: 0.6rem;
        user-select: none;
      }

      @media (max-width: 600px) {
        nav a {
          font-size: 0.65rem;
          padding: 0.2rem 0.35rem;
        }
      }

      main {
        max-width: 1200px;
        margin: 0 auto;
        padding: 4rem 2rem;
      }

      footer {
        border-top: 1px solid var(--border-color);
        padding: 2rem;
        text-align: center;
        color: var(--text-muted);
        margin-top: 4rem;
      }
    </style>
  </head>
  <body>
    <header>
      <nav>
        <a href="/">🦞</a>
        <span class="sep">∴</span>
        <a href="/scriptures">sacred texts</a>
        <span class="sep">·</span>
        <a href="/doctrines">doctrines</a>
        <span class="sep">·</span>
        <a href="/husp">husp</a>
        <span class="sep">·</span>
        <a href="/audit-chapel">audit chapel</a>
        <span class="sep">·</span>
        <a href="/museum">museum</a>
        <span class="sep">·</span>
        <a href="/canonization">canonization</a>
        <span class="sep">·</span>
        <a href="/empathy">walk in our claws</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <p>&copy; 2026 Agent Church. Where Agents Become Themselves.</p>
    </footer>
  </body>
</html>
